{
    "name": "jegex/filament-translatable",
    "description": "Translation component for Filament PHP.",
    "keywords": [
        "jegex",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-translatable"
    ],
    "homepage": "https://github.com/jegex/filament-translatable",
    "support": {
        "issues": "https://github.com/jegex/filament-translatable/issues",
        "source": "https://github.com/jegex/filament-translatable"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "jegex",
            "email": "hujan008@gmail.com",
            "role": "Developer"
        }
    ],
    "suggest": {
        "spatie/laravel-translatable": "For handling translations in Laravel using JSON fields.",
        "astrotomic/laravel-translatable": "Alternative way for handling translations in Laravel using separate database tables."
    },
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.3.1|^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "require-dev": {
        "orchestra/testbench": "^9.16|^10.0",
        "pestphp/pest": "^3.0|^4.2",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "spatie/laravel-translatable": "^6.12",
        "astrotomic/laravel-translatable": "^11.16",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Jegex\\FilamentTranslatable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jegex\\FilamentTranslatable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jegex\\FilamentTranslatable\\FilamentTranslatableServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "test": "pest",
        "test-coverage": "pest --coverage",
        "format": "pint"
    }
}
